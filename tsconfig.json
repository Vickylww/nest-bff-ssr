{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,   // 必须
    "emitDecoratorMetadata": true,    // 必须
  },
  "include": ["src/*/*.ts"],
  "exclude": ["node_modules","dist", "vue"]            
}